# Si nano Factory — environment variables template
# Copy to .env and adjust. .env is git-ignored.

# --- Postgres ---------------------------------------------------------
POSTGRES_USER=factory
POSTGRES_PASSWORD=factory_dev_password_change_me
POSTGRES_DB=factory
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- MinIO (S3-compatible object storage) -----------------------------
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=factory
MINIO_SECRET_KEY=factory_dev_password_change_me
MINIO_BUCKET_DVC=factory-dvc
MINIO_BUCKET_MLFLOW=factory-mlflow
MINIO_BUCKET_TRAJECTORIES=factory-trajectories

# --- Prefect ----------------------------------------------------------
PREFECT_API_URL=http://localhost:4200/api

# --- MLflow -----------------------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=factory
AWS_SECRET_ACCESS_KEY=factory_dev_password_change_me

# --- Hardware budgets (NFR-15) ----------------------------------------
FACTORY_GPU_MIN_FREE_VRAM_GB=20
FACTORY_GPU_MAX_BATCH_FALLBACK_STEPS=3
FACTORY_DISK_TRAJECTORY_RETENTION_DAYS=7

# --- HPC backend (§14, optional) --------------------------------------
# FACTORY_BACKEND=local            # local | slurm | aws-batch | runpod | lumi
# FACTORY_HPC_HOST=jureca.fz-juelich.de
# FACTORY_HPC_USER=
# FACTORY_HPC_SSH_KEY=~/.ssh/id_factory_hpc
# FACTORY_HPC_ALLOCATION=eurohpc-2026-1234

# --- Notifications (Module 3, Phase 3) --------------------------------
# FACTORY_NOTIFY_TELEGRAM_TOKEN=
# FACTORY_NOTIFY_TELEGRAM_CHAT_ID=
# FACTORY_NOTIFY_SLACK_WEBHOOK=

# --- IP / patent flags ------------------------------------------------
FACTORY_IP_MODE=open                # open | hybrid (R-06 time-based release)
